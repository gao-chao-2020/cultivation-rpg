<Window x:Class="CultivationRPG.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CultivationRPG.ViewModels"
        Title="Cultivation RPG" Height="620" Width="840" MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterScreen" Background="#0F0F23">
    <Window.DataContext><vm:MainViewModel/></Window.DataContext>
    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Width="3" Background="Transparent"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.Thumb><Thumb><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="#555" CornerRadius="2" Width="3"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb></Track></Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="Card" Color="#1A1A35"/>
        <SolidColorBrush x:Key="Card2" Color="#1E1E3A"/>
        <SolidColorBrush x:Key="Text" Color="#D0D0E8"/>
        <SolidColorBrush x:Key="Dim" Color="#707090"/>
        <SolidColorBrush x:Key="Gold" Color="#F0C040"/>
        <SolidColorBrush x:Key="Purple" Color="#A060D0"/>
        <SolidColorBrush x:Key="Blue" Color="#5090E0"/>
        <SolidColorBrush x:Key="Green" Color="#40B070"/>
        <SolidColorBrush x:Key="Orange" Color="#E09040"/>
        <SolidColorBrush x:Key="Red" Color="#D04050"/>

        <Style x:Key="StatLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
        </Style>
        <Style x:Key="StatVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANEL ═══ -->
        <Border Grid.Column="0" Background="{StaticResource Card}" CornerRadius="12" Padding="22" Margin="0,0,6,0">
            <StackPanel>
                <!-- Name -->
                <Grid Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}, ConverterParameter=invert}">
                        <TextBlock Text="{Binding PlayerName}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gold}"/>
                        <Button Content="✎" Width="22" Height="18" FontSize="10" Background="Transparent" Foreground="#555" BorderThickness="0" Cursor="Hand" Command="{Binding StartEditCommand}" VerticalAlignment="Center" Margin="6,2,0,0"/>
                        <Button Content="重生" Width="40" Height="20" FontSize="10" Margin="16,2,0,0"
                                Background="#6030A0" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Command="{Binding RebornCommand}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" Foreground="#D0D0E8" Background="#0F0F23" BorderBrush="#444" CaretBrush="White" Width="130"/>
                        <Button Content="✓" Width="28" Height="26" FontSize="14" Margin="6,0,0,0" Background="{StaticResource Purple}" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding SaveNameCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- Realm -->
                <Border Background="#1E1E3A" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="境界" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Realm}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Purple}"/>
                            <TextBlock Text="{Binding Title}" FontSize="14" Foreground="{StaticResource Dim}" VerticalAlignment="Bottom" Margin="8,0,0,6"/>
                        </StackPanel>
                        <Grid Margin="0,10,0,0">
                            <Border Height="14" CornerRadius="7" Background="#0F0F23"/>
                            <Border Height="14" CornerRadius="7" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6040A0" Offset="0"/><GradientStop Color="#A060D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Width>
                                    <Binding Path="RealmProgress" Converter="{x:Static vm:ProgressWidthConverter.Instance}"/>
                                </Border.Width>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Xp, StringFormat={}{0:N0}}" FontSize="11" Foreground="{StaticResource Dim}"/>
                            <TextBlock Text=" / " FontSize="11" Foreground="{StaticResource Dim}"/>
                            <TextBlock Text="{Binding XpToNext, StringFormat={}{0:N0}}" FontSize="11" Foreground="{StaticResource Dim}"/>
                            <TextBlock Text=" XP" FontSize="11" Foreground="{StaticResource Dim}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stats 2x2 -->
                <UniformGrid Columns="2" Rows="2">
                    <Border Background="#1E1E3A" CornerRadius="8" Margin="3" Padding="12">
                        <StackPanel>
                            <TextBlock Text="灵力 · Spirit" Style="{StaticResource StatLbl}"/>
                            <TextBlock Text="{Binding Spirit}" Style="{StaticResource StatVal}" Foreground="{StaticResource Blue}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E3A" CornerRadius="8" Margin="3" Padding="12">
                        <StackPanel>
                            <TextBlock Text="身法 · Agility" Style="{StaticResource StatLbl}"/>
                            <TextBlock Text="{Binding Agility}" Style="{StaticResource StatVal}" Foreground="{StaticResource Green}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E3A" CornerRadius="8" Margin="3" Padding="12">
                        <StackPanel>
                            <TextBlock Text="神识 · Wisdom" Style="{StaticResource StatLbl}"/>
                            <TextBlock Text="{Binding Wisdom}" Style="{StaticResource StatVal}" Foreground="{StaticResource Orange}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E3A" CornerRadius="8" Margin="3" Padding="12">
                        <StackPanel>
                            <TextBlock Text="炼丹 · Alchemy" Style="{StaticResource StatLbl}"/>
                            <TextBlock Text="{Binding Alchemy}" Style="{StaticResource StatVal}" Foreground="{StaticResource Red}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ═══ RIGHT PANEL ═══ -->
        <Grid Grid.Column="1" Margin="6,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Today -->
            <Border Grid.Row="0" Background="{StaticResource Card}" CornerRadius="12" Padding="18" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="今日修炼" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,0,0,10"/>
                    <UniformGrid Columns="5">
                        <StackPanel Margin="0,4">
                            <TextBlock Text="灵力" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TodayKeys}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Blue}"/>
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="身法" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TodayDist}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Green}"/>
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="神识" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TodayActive}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Orange}"/>
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="炼丹" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TodayClicks}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Red}"/>
                        </StackPanel>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="修为" Style="{StaticResource StatLbl}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TodayXp}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gold}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Leaderboard -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="排行榜" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gold}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" x:Name="TabPanel">
                        <Button Content="今日" Tag="0" Click="OnTabClick"/>
                        <Button Content="昨日" Tag="1" Click="OnTabClick"/>
                        <Button Content="总榜" Tag="2" Click="OnTabClick"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Background="{StaticResource Card}" CornerRadius="12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="{Binding MyRank}" FontSize="11" Foreground="{StaticResource Dim}" Margin="0,0,0,4"/>
                        <Grid Grid.Row="1" Height="22" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="#555"/>
                            <TextBlock Grid.Column="1" Text="道号" FontSize="10" Foreground="#555"/>
                            <TextBlock Grid.Column="2" Text="境界" FontSize="10" Foreground="#555"/>
                            <TextBlock Grid.Column="3" Text="修为" FontSize="10" Foreground="#555" HorizontalAlignment="Right"/>
                        </Grid>
                        <ScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding Leaderboard}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="30" Margin="0,1.5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/><ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/><ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding RankColor}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PlayerName}" FontSize="13"
                                                       Foreground="{Binding RankColor}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Realm}" FontSize="11" Foreground="{StaticResource Purple}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding XpDisplay}" FontSize="12" Foreground="{StaticResource Gold}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
