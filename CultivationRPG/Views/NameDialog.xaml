<Window x:Class="CultivationRPG.Views.NameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="道号" Height="170" Width="320" WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="NoResize" Background="#252542">
    <StackPanel Margin="20">
        <TextBlock Text="取一个道号" FontSize="16" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,12"/>
        <TextBox x:Name="NameBox" Height="32" FontSize="14" Background="#1A1A2E"
                 Foreground="#E0E0F0" BorderBrush="#444" CaretBrush="White" Margin="0,0,0,12"/>
        <Button Content="确认" Height="32" Background="#C040E0" Foreground="White" FontSize="14"
                BorderThickness="0" Click="OnConfirm" IsDefault="True"/>
    </StackPanel>
</Window>
